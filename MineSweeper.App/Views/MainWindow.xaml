<Window x:Class="MineSweeper.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MineSweeper"
        Height="700"
        Width="700"
        WindowStartupLocation="CenterScreen">

    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="MineSweeper"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,8" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Difficulty:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <ComboBox Width="150"
                          ItemsSource="{Binding AvailableDifficulties}"
                          SelectedItem="{Binding SelectedDifficulty}"
                          Margin="0,0,12,0" />

                <Button Content="New Game"
                        Width="100"
                        Command="{Binding NewGameCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding GameStatus}"
                       FontSize="14"
                       FontWeight="SemiBold" />
        </StackPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="{Binding Rows}" Columns="{Binding Columns}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding DisplayText}"
                                Margin="2"
                                FontSize="16"
                                FontWeight="Bold"
                                MinWidth="32"
                                MinHeight="32"
                                Command="{Binding DataContext.RevealCellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                MouseRightButtonUp="Cell_RightClick" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>