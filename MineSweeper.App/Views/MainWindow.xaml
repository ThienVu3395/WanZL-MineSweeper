<Window x:Class="MineSweeper.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:MineSweeper.App.Helpers"
        mc:Ignorable="d"
        Title="MineSweeper"
        Height="700"
        Width="700"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">

    <!-- RESOURCES -->
    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:DifficultyToStringConverter x:Key="DifficultyConverter"/>
    </Window.Resources>

    <!-- ROOT GRID -->
    <Grid>

        <!-- ================= MAIN UI ================= -->
        <DockPanel Margin="16">

            <!-- HEADER -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">

                <!-- Title -->
                <TextBlock Text="MineSweeper"
                           FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,6" />

                <!-- Tips -->
                <TextBlock Text="* Tips: Double-click a revealed number cell to chord • F2 = Restart • Ctrl+1/2/3/4 = Difficulty shortcuts"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- Primary controls -->
                <Border Background="#F8F8F8"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Difficulty:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableDifficulties}"
                                  SelectedItem="{Binding SelectedDifficulty}"
                                  VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource DifficultyConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Button Grid.Column="3"
                                x:Name="NewGameButton"
                                Content="New Game"
                                Width="110"
                                Height="32"
                                Click="NewGameButton_Click" />
                    </Grid>
                </Border>

                <!-- Custom difficulty configuration -->
                <Border Margin="0,0,0,10"
                        Padding="12"
                        Background="#F7F7F7"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="8">

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCustomDifficultySelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <TextBlock Text="Custom configuration"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Rows"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            
                            <TextBox Grid.Column="1"  Text="{Binding CustomRows, UpdateSourceTrigger=LostFocus}" />

                            <TextBlock Grid.Column="3"
                                       Text="Columns"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            
                            <TextBox Grid.Column="4" Text="{Binding CustomColumns, UpdateSourceTrigger=LostFocus}" />

                            <TextBlock Grid.Column="6"
                                   Text="Mines"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0" />
                            
                             <TextBox Grid.Column="7" 
                                      Text="{Binding CustomMines, UpdateSourceTrigger=LostFocus}" />
                        </Grid>

                        <TextBlock Text="{Binding CustomBoardSummary, StringFormat=Preview: {0}}"
                                   FontSize="12"
                                   Foreground="Gray"
                                   Margin="0,8,0,0" />

                        <TextBlock Text="Allowed range: rows 5–30, columns 5–30, mines must leave at least one safe cell."
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock Text="{Binding GameStatus}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />

                <TextBlock Text="{Binding Message}"
                           Foreground="OrangeRed"
                           FontSize="12"
                           Margin="0,0,0,10"
                           Visibility="{Binding Message, Converter={StaticResource NullToVisibilityConverter}}" />

                <!-- Stats card -->
                <Border Background="#FAFAFA"
                        BorderBrush="#E1E1E1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,6">
                    <UniformGrid Columns="5">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Mines"
                                       FontSize="11"
                                       Foreground="Gray" />
                            <TextBlock Text="{Binding TotalMines}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Flags"
                                       FontSize="11"
                                       Foreground="Gray" />
                            <TextBlock Text="{Binding FlagCount}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Remaining"
                                       FontSize="11"
                                       Foreground="Gray" />
                            <TextBlock Text="{Binding RemainingMines}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Time"
                                       FontSize="11"
                                       Foreground="Gray" />
                            <TextBlock Text="{Binding ElapsedTimeDisplay}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Best"
                                       FontSize="11"
                                       Foreground="Gray" />
                            <TextBlock Text="{Binding BestTimeDisplay}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                        </StackPanel>
                    </UniformGrid>
                </Border>

                <TextBlock Text="{Binding BestTimesFilePath, StringFormat=Best times are stored at: {0}}"
                           FontSize="12"
                           Foreground="Gray"
                           TextWrapping="Wrap" />

                <TextBlock Text="{Binding PlayerPreferencesFilePath, StringFormat=Preferences are stored at: {0}}"
                           FontSize="12"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- GAME BOARD -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="{Binding Rows}"
                                         Columns="{Binding Columns}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Button Content="{Binding DisplayText}"
                                    Margin="2"
                                    FontSize="18"
                                    FontFamily="Segoe UI Emoji"
                                    FontWeight="Bold"
                                    MinWidth="36"
                                    MinHeight="36"
                                    Command="{Binding DataContext.RevealCellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    MouseRightButtonUp="Cell_RightClick"
                                    MouseDoubleClick="Cell_MouseDoubleClick">

                                <Button.Style>
                                    <Style TargetType="Button">

                                        <!-- Default -->
                                        <Setter Property="Background" Value="#DADADA" />
                                        <Setter Property="BorderBrush" Value="#9E9E9E" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Cursor" Value="Hand" />

                                        <Style.Triggers>

                                            <!-- Hover (only when hidden & game active) -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="False"/>
                                                    <Condition Binding="{Binding DataContext.IsGameFinished, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#E8E8E8" />
                                                <Setter Property="BorderBrush" Value="#7F7F7F" />
                                            </MultiDataTrigger>

                                            <!-- Pressed -->
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#C8C8C8" />
                                                <Setter Property="BorderBrush" Value="#6F6F6F" />
                                            </Trigger>

                                            <!-- Disabled -->
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.75"/>
                                            </Trigger>

                                            <!-- Revealed -->
                                            <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                <Setter Property="Background" Value="#F4F4F4" />
                                                <Setter Property="BorderBrush" Value="#CFCFCF" />
                                            </DataTrigger>

                                            <!-- Flag (hidden) -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsFlagged}" Value="True"/>
                                                    <Condition Binding="{Binding IsRevealed}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#FFF4F4"/>
                                                <Setter Property="Foreground" Value="DarkRed"/>
                                                <Setter Property="BorderBrush" Value="#C97B7B"/>
                                            </MultiDataTrigger>

                                            <!-- Number colors -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="1"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Blue"/>
                                            </MultiDataTrigger>

                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="2"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Green"/>
                                            </MultiDataTrigger>

                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="3"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Red"/>
                                            </MultiDataTrigger>

                                            <!-- Exploded mine -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsExplodedMine}" Value="True"/>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#FF4D4D"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#990000"/>
                                                <Setter Property="FontSize" Value="20"/>
                                            </MultiDataTrigger>

                                            <!-- Incorrect flag -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsIncorrectFlag}" Value="True"/>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#FFF0F0"/>
                                                <Setter Property="Foreground" Value="#B30000"/>
                                                <Setter Property="BorderBrush" Value="#D28A8A"/>
                                            </MultiDataTrigger>

                                            <!-- Mine -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsMine}" Value="True"/>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#FFD6D6"/>
                                                <Setter Property="Foreground" Value="DarkRed"/>
                                            </MultiDataTrigger>

                                            <!-- Game finished -->
                                            <DataTrigger Binding="{Binding DataContext.IsGameFinished, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Opacity" Value="0.88"/>
                                            </DataTrigger>

                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- ================= TOAST OVERLAY ================= -->
        <Border Background="#DD333333"
                CornerRadius="8"
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0"
                Opacity="0"
                IsHitTestVisible="False"
                x:Name="ToastMessage">

            <TextBlock Text="{Binding Message}"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- ================= ENDGAME DIALOG OVERLAY ================= -->
        <Border x:Name="EndGameDialogOverlay"
                Background="#80000000"
                Visibility="Collapsed"
                Panel.ZIndex="20">

            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="24">

                <Border x:Name="EndGameDialog"
                        Width="380"
                        MaxWidth="420"
                        Padding="20"
                        Background="White"
                        BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        CornerRadius="12">

                    <StackPanel>
                        <TextBlock x:Name="EndGameDialogTitle"
                                   Text="Game Over"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10" />

                        <TextBlock x:Name="EndGameDialogMessage"
                                   Text="The game has ended."
                                   FontSize="14"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <Border Background="#F7F7F7"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{Binding ElapsedTimeDisplay, StringFormat=Time: {0}}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />

                                <TextBlock Text="{Binding BestTimeDisplay, StringFormat=Best: {0}}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />

                                <TextBlock Text="{Binding SelectedDifficulty, Converter={StaticResource DifficultyConverter}, StringFormat=Difficulty: {0}}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button x:Name="PlayAgainButton"
                                    Content="Play Again"
                                    Width="120"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="PlayAgainButton_Click" />

                            <Button x:Name="CloseDialogButton"
                                    Content="Close"
                                    Width="100"
                                    Height="34"
                                    Click="CloseDialogButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ================= RESTART CONFIRMATION OVERLAY ================= -->
        <Border x:Name="RestartConfirmationOverlay"
                Background="#80000000"
                Visibility="Collapsed"
                Panel.ZIndex="30">

            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="24">

                <Border x:Name="RestartConfirmationDialog"
                        Width="400"
                        MaxWidth="440"
                        Padding="20"
                        Background="White"
                        BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        CornerRadius="12">

                    <StackPanel>
                        <TextBlock x:Name="RestartConfirmationTitle"
                           Text="Restart game?"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />

                        <TextBlock x:Name="RestartConfirmationMessage"
                           Text="Your current progress will be lost."
                           FontSize="14"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14" />

                        <Border Background="#FFF7E6"
                                BorderBrush="#F0C36D"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,14">
                            <TextBlock Text="Unsaved progress in the current game will be discarded."
                                       FontSize="12"
                                       Foreground="#8A5A00"
                                       TextWrapping="Wrap" />
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button x:Name="ConfirmRestartButton"
                                    Content="Continue"
                                    Width="120"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="ConfirmRestartButton_Click" />

                            <Button x:Name="CancelRestartButton"
                                    Content="Cancel"
                                    Width="100"
                                    Height="34"
                                    Click="CancelRestartButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>