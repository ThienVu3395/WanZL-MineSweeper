<Window x:Class="MineSweeper.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:MineSweeper.App.Helpers"
        mc:Ignorable="d"
        Title="MineSweeper"
        Height="700"
        Width="700"
        WindowStartupLocation="CenterScreen">

    <!-- RESOURCES -->
    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:DifficultyToStringConverter x:Key="DifficultyConverter"/>
    </Window.Resources>

    <!-- ROOT GRID -->
    <Grid>

        <!-- ================= MAIN UI ================= -->
        <DockPanel Margin="16">

            <!-- HEADER -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">

                <TextBlock Text="MineSweeper"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,10" />

                <TextBlock Text="* Tip: Double-click a revealed number cell to chord."
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="Gray"
                           Margin="0,0,0,10" />

                <!-- Difficulty + New Game -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,10">
                    <TextBlock Text="Difficulty:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <ComboBox Width="200"
                              ItemsSource="{Binding AvailableDifficulties}"
                              SelectedItem="{Binding SelectedDifficulty}"
                              Margin="0,0,12,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource DifficultyConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Content="New Game"
                            Width="110"
                            Height="30"
                            Command="{Binding NewGameCommand}" />
                </StackPanel>

                <!-- Custom difficulty configuration -->
                <Border Margin="0,0,0,10"
                        Padding="10"
                        Background="#F7F7F7"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        CornerRadius="6">

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCustomDifficultySelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <TextBlock Text="Custom configuration"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Rows" Margin="0,0,0,4" />
                                <TextBox Width="70" Text="{Binding CustomRows, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Columns" Margin="0,0,0,4" />
                                <TextBox Width="70" Text="{Binding CustomColumns, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Mines" Margin="0,0,0,4" />
                                <TextBox Width="70" Text="{Binding CustomMines, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding CustomBoardSummary, StringFormat=Preview: {0}}"
                           FontSize="12"
                           Foreground="Gray"
                           Margin="0,8,0,0" />

                        <TextBlock Text="Allowed range: rows 5-30, columns 5-30, mines must leave at least one safe cell."
                           FontSize="11"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Game Status -->
                <TextBlock Text="{Binding GameStatus}"
                           FontSize="14"
                           FontWeight="SemiBold" />

                <!-- Optional inline message (fallback nếu không dùng toast) -->
                <TextBlock Text="{Binding Message}"
                           Foreground="OrangeRed"
                           FontSize="12"
                           Margin="0,4,0,0"
                           Visibility="{Binding Message, Converter={StaticResource NullToVisibilityConverter}}" />

                <!-- Counters -->
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">

                    <TextBlock Text="{Binding TotalMines, StringFormat=Mines: {0}}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0" />

                    <TextBlock Text="{Binding FlagCount, StringFormat=Flags: {0}}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0" />

                    <TextBlock Text="{Binding RemainingMines, StringFormat=Remaining: {0}}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0" />

                    <TextBlock Text="{Binding ElapsedTimeDisplay, StringFormat=Time: {0}}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,16,0" />

                    <TextBlock Text="{Binding BestTimeDisplay, StringFormat=Best: {0}}"
                               FontSize="13"
                               FontWeight="SemiBold" />
                </StackPanel>

                <TextBlock Text="{Binding BestTimesFilePath, StringFormat=Best times are stored at: {0}}"
                               FontSize="12"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
            </StackPanel>

            <!-- GAME BOARD -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">

                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="{Binding Rows}"
                                         Columns="{Binding Columns}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Button Content="{Binding DisplayText}"
                                    Margin="2"
                                    FontSize="18"
                                    FontFamily="Segoe UI Emoji"
                                    FontWeight="Bold"
                                    MinWidth="36"
                                    MinHeight="36"
                                    Command="{Binding DataContext.RevealCellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    MouseRightButtonUp="Cell_RightClick"
                                    MouseDoubleClick="Cell_MouseDoubleClick">

                                <Button.Style>
                                    <Style TargetType="Button">

                                        <!-- Default -->
                                        <Setter Property="Background" Value="LightGray" />
                                        <Setter Property="BorderBrush" Value="Gray" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Foreground" Value="Black" />
                                        <Setter Property="Padding" Value="0" />

                                        <Style.Triggers>

                                            <!-- Hover -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#DCDCDC" />
                                            </Trigger>

                                            <!-- Disabled -->
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.6"/>
                                            </Trigger>

                                            <!-- Revealed -->
                                            <DataTrigger Binding="{Binding IsRevealed}" Value="True">
                                                <Setter Property="Background" Value="#F3F3F3" />
                                                <Setter Property="BorderBrush" Value="#C8C8C8" />
                                            </DataTrigger>

                                            <!-- Flag -->
                                            <DataTrigger Binding="{Binding IsFlagged}" Value="True">
                                                <Setter Property="Foreground" Value="DarkRed" />
                                            </DataTrigger>

                                            <!-- Colored Numbers -->
                                            <!-- 1 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="1"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Blue"/>
                                            </MultiDataTrigger>

                                            <!-- 2 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="2"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Green"/>
                                            </MultiDataTrigger>

                                            <!-- 3 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="3"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Red"/>
                                            </MultiDataTrigger>

                                            <!-- 4 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="4"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="DarkBlue"/>
                                            </MultiDataTrigger>

                                            <!-- 5 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="5"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Brown"/>
                                            </MultiDataTrigger>

                                            <!-- 6 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="6"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Cyan"/>
                                            </MultiDataTrigger>

                                            <!-- 7 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="7"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Black"/>
                                            </MultiDataTrigger>

                                            <!-- 8 -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                    <Condition Binding="{Binding AdjacentMines}" Value="8"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </MultiDataTrigger>

                                            <!-- Exploded mine -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsExplodedMine}" Value="True"/>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#FF4D4D"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#B30000"/>
                                                <Setter Property="FontSize" Value="20"/>
                                            </MultiDataTrigger>

                                            <!-- Incorrect flag -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsIncorrectFlag}" Value="True"/>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#FFE5E5"/>
                                                <Setter Property="Foreground" Value="#B30000"/>
                                                <Setter Property="BorderBrush" Value="#CC6666"/>
                                            </MultiDataTrigger>

                                            <!-- Mine -->
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsMine}" Value="True"/>
                                                    <Condition Binding="{Binding IsRevealed}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Background" Value="#FFB3B3"/>
                                                <Setter Property="Foreground" Value="DarkRed"/>
                                            </MultiDataTrigger>

                                            <!-- Game finished -->
                                            <DataTrigger Binding="{Binding DataContext.IsGameFinished, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Value="True">
                                                <Setter Property="Opacity" Value="0.8" />
                                            </DataTrigger>

                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- ================= TOAST OVERLAY ================= -->
        <Border Background="#DD333333"
                CornerRadius="8"
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,20,0,0"
                Opacity="0"
                IsHitTestVisible="False"
                x:Name="ToastMessage">

            <TextBlock Text="{Binding Message}"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>

        <!-- ================= ENDGAME DIALOG OVERLAY ================= -->
        <Border x:Name="EndGameDialogOverlay"
                Background="#80000000"
                Visibility="Collapsed"
                Panel.ZIndex="20">

            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Margin="24">

                <Border x:Name="EndGameDialog"
                        Width="380"
                        MaxWidth="420"
                        Padding="20"
                        Background="White"
                        BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        CornerRadius="12">

                    <StackPanel>
                        <TextBlock x:Name="EndGameDialogTitle"
                                   Text="Game Over"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10" />

                        <TextBlock x:Name="EndGameDialogMessage"
                                   Text="The game has ended."
                                   FontSize="14"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <Border Background="#F7F7F7"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{Binding ElapsedTimeDisplay, StringFormat=Time: {0}}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />

                                <TextBlock Text="{Binding BestTimeDisplay, StringFormat=Best: {0}}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4" />

                                <TextBlock Text="{Binding SelectedDifficulty, Converter={StaticResource DifficultyConverter}, StringFormat=Difficulty: {0}}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button x:Name="PlayAgainButton"
                                    Content="Play Again"
                                    Width="120"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    Click="PlayAgainButton_Click" />

                            <Button x:Name="CloseDialogButton"
                                    Content="Close"
                                    Width="100"
                                    Height="34"
                                    Click="CloseDialogButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>